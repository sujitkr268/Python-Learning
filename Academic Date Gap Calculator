from datetime import date
import sys

def main():
    try:
        # Read all inputs from standard input and split by lines
        input_data = sys.stdin.read().splitlines()
        if len(input_data) < 2:
            return
        
        # Strip potential whitespace from the input strings
        d1 = input_data[0].strip()
        d2 = input_data[1].strip()
        
        # Parse years, months, and days
        y1, m1, day1 = map(int, d1.split('-'))
        y2, m2, day2 = map(int, d2.split('-'))
        
        # Create date objects (handles leap years automatically)
        date1 = date(y1, m1, day1)
        date2 = date(y2, m2, day2)
        
        # Calculate absolute difference in days
        diff = abs((date2 - date1).days)
        
        # Print the final result integer
        print(diff)
        
    except Exception:
        # Graceful fallback in case of parsing errors
        print(0)

if __name__ == "__main__":
    main()
