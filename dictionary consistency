import sys

def check_consistency(lst):
    # Rule: A list with 0 or 1 element is considered consistent
    if len(lst) <= 1:
        return True
    
    # Calculate the common difference from the first pair
    diff = lst[1] - lst[0]
    
    # Condition 1: Strictly increasing means diff must be greater than 0
    if diff <= 0:
        return False
        
    # Condition 2: Check if the difference remains the same throughout
    for i in range(len(lst) - 1):
        if lst[i + 1] - lst[i] != diff:
            return False
            
    return True

def main():
    # Take input from the user and safely parse the dictionary
    try:
        user_input = sys.stdin.read().strip()
        if not user_input:
            print(0)
            return
        records = eval(user_input)
    except:
        print(0)
        return

    count = 0
    # Iterate through the lists inside the dictionary
    for key in records:
        if check_consistency(records[key]):
            count += 1
            
    # Print only the final count integer
    print(count)

if __name__ == "__main__":
    main()
